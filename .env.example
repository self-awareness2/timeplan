# Required for any production deployment. Generate at least 32 random characters.
CHRONA_ENV=production
CHRONA_SECRET=replace-with-a-long-random-secret

# Comma-separated origins for Capacitor, a future mini program bridge, or another web host.
CHRONA_ALLOWED_ORIGINS=https://chrona.example.com

# Host port for Docker Compose.
CHRONA_PORT=8765

# Maximum failed login/register attempts per IP in a 15-minute window.
CHRONA_AUTH_MAX_ATTEMPTS=10
